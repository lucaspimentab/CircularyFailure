# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Env
.env
.env.*

# Jupyter
.ipynb_checkpoints/

# Data / outputs (kept in repo per current request)
/data/
/outputs/**
/_archive_local/

# Large data formats (kept in repo per current request)
*.h5
*.hdf5
*.parquet
*.npy
*.npz
*.pt
*.pth
*.ckpt

# Logs (kept in repo per current request)
*.log

# OS
.DS_Store
Thumbs.db

!.env.example

# Allow publishable outputs (metrics/figures only)
!outputs/
!outputs/*/
!outputs/*/reports/
!outputs/*/reports/**/*.csv
!outputs/*/reports/**/*.json
!outputs/*/reports/**/*.txt
!outputs/*/reports/**/*.md
!outputs/*/reports/**/*.png
!outputs/*/reports/**/*.pdf
!outputs/*/clustering/
!outputs/*/clustering/minirocket/
!outputs/*/clustering/minirocket/clusters_minirocket/
!outputs/*/clustering/minirocket/clusters_minirocket/*.csv
!outputs/*/clustering/minirocket/clusters_minirocket/*.json

# Never publish heavy artifacts even under report-like folders
outputs/*/reports/**/cache_perstay/**
outputs/*/reports/**/*.parquet
outputs/*/reports/**/*.h5
outputs/*/reports/**/*.hdf5
outputs/*/reports/**/*.npy
outputs/*/reports/**/*.npz
outputs/*/reports/**/*.pt
outputs/*/reports/**/*.pth
outputs/*/reports/**/*.ckpt
